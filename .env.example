APP_ENV=
DEBUG=

# ── CORS (separado por comas) ─────────────────────────────────────────────────
CORS_ORIGINS=

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# formato: postgresql+asyncpg://usuario:password@host:puerto/nombre_db
DATABASE_URL=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=

# ── Auth JWT ──────────────────────────────────────────────────────────────────
# generar con: openssl rand -hex 32
JWT_SECRET_KEY=
JWT_ALGORITHM=
JWT_EXPIRE_MINUTES=

# ── Cohere (embeddings) ───────────────────────────────────────────────────────
# obtener gratis en: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=
COHERE_EMBED_MODEL=

# ── Google Gemini (LLM) ───────────────────────────────────────────────────────
# obtener gratis en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=

# ── Cloudflare R2 (imágenes productos) ───────────────────────────────────────
# obtener gratis en: https://dash.cloudflare.com → R2
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT_URL=
